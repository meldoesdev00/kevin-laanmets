   HERO
================================================================ */

function Hero() {
  const [current, setCurrent] = useState(0);

  useEffect(() => {
    const id = setInterval(
      () => setCurrent((c) => (c + 1) % HERO_IMAGES.length),
      5000
    );
    return () => clearInterval(id);
  }, []);

  return (
    <section className="relative h-screen w-full overflow-hidden">
      {/* Slideshow */}
      {HERO_IMAGES.map((src, i) => (
        <div
          key={src}
          className="absolute inset-0 transition-opacity duration-[1400ms] ease-in-out"
          style={{ opacity: i === current ? 1 : 0 }}
        >
          <Image
            src={src}
            alt="Real estate"
            fill
            className="object-cover"
            priority={i === 0}
            sizes="100vw"
          />
        </div>
      ))}

      {/* Overlay */}
      <div className="absolute inset-0 bg-black/38" />

      {/* Content */}
      <div className="relative z-10 flex h-full flex-col justify-center px-8 md:px-20 max-w-5xl">
        <span className="mb-5 text-[0.68rem] tracking-[0.35em] uppercase text-white/60 font-light">
          Real Estate · Tallinn
        </span>

        <h1 className="font-serif text-[3.4rem] md:text-[5.5rem] leading-[1.04] font-light text-white mb-7">
          Your home,
          <br />
          <em>your story.</em>
          <br />
          I&apos;ll find it.
        </h1>

        <p className="mb-10 max-w-md text-white/65 font-light leading-relaxed text-[1.05rem]">
          Transparent, personal and results-driven real estate brokerage in
          Tallinn and beyond.
        </p>

        <a
          href="#contact"
          className="self-start rounded-full bg-racing-green px-9 py-4 text-[0.72rem] tracking-[0.18em] uppercase text-white font-light hover:bg-racing-green-dark transition-all duration-300 hover:scale-[1.03]"
        >
          Contact me
        </a>
      </div>

      {/* Scroll cue */}
      <div className="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/40">
        <span className="text-[0.6rem] tracking-[0.3em] uppercase">Scroll</span>
        <div className="h-10 w-px bg-white/25 animate-pulse" />
      </div>

      {/* Slide dots */}
      <div className="absolute bottom-10 right-10 flex gap-2">
        {HERO_IMAGES.map((_, i) => (
          <button
            key={i}
            onClick={() => setCurrent(i)}
            className={`rounded-full transition-all duration-300 ${
              i === current
                ? "w-6 h-1.5 bg-white"
                : "w-1.5 h-1.5 bg-white/40 hover:bg-white/70"
            }`}
          />
        ))}
      </div>
