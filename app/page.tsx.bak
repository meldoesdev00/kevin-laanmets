/* ================================================================
   SALES PROCESS
================================================================ */

function SalesProcess() {
  const titleRef = useRef<HTMLDivElement>(null);
  const [titleVisible, setTitleVisible] = useState(false);

  const stepRefs = useRef<(HTMLDivElement | null)[]>([]);
  const [stepsVisible, setStepsVisible] = useState<boolean[]>(
    STEPS.map(() => false)
  );

  useEffect(() => {
    const el = titleRef.current;
    if (!el) return;
    const obs = new IntersectionObserver(
      ([e]) => {
        if (e.isIntersecting) setTitleVisible(true);
      },
      { threshold: 0.3 }
    );
    obs.observe(el);
    return () => obs.disconnect();
  }, []);

  useEffect(() => {
    const observers = stepRefs.current.map((el, i) => {
      if (!el) return null;
      const obs = new IntersectionObserver(
        ([e]) => {
          if (e.isIntersecting) {
            setTimeout(() => {
              setStepsVisible((prev) => {
                const next = [...prev];
                next[i] = true;
                return next;
              });
            }, i * 120);
          }
        },
        { threshold: 0.2 }
      );
      obs.observe(el);
      return obs;
    });
    return () => observers.forEach((obs) => obs?.disconnect());
  }, []);

  return (
    <section className="py-28 md:py-40 bg-racing-green overflow-hidden">
      <div className="mx-auto max-w-6xl px-6 md:px-16">
        {/* Section title */}
        <div
          ref={titleRef}
          className={`mb-20 text-center transition-all duration-1000 ${
            titleVisible
              ? "opacity-100 translate-y-0"
              : "opacity-0 translate-y-8"
          }`}
        >
          <span className="mb-4 text-[0.68rem] tracking-[0.35em] uppercase text-white/40 font-light block">
            How it works
          </span>
          <h2 className="font-serif text-[2.8rem] md:text-[5rem] font-light text-white leading-[1.04]">
            Sales Process
          </h2>
        </div>

        {/* Steps */}
        <div className="relative">
          {/* Vertical connector line */}
          <div className="absolute left-[2.35rem] md:left-1/2 top-0 bottom-0 w-px bg-white/10 md:-translate-x-px" />

          <div className="space-y-10">
            {STEPS.map((step, i) => {
              const isRight = i % 2 !== 0;
              return (
                <div
                  key={i}
                  ref={(el) => {
                    stepRefs.current[i] = el;
                  }}
                  className={`step-card relative flex items-start gap-6 md:gap-10 ${
                    isRight ? "md:flex-row-reverse" : "md:flex-row"
                  } ${stepsVisible[i] ? "step-visible" : ""}`}
                >
                  {/* Spacer (desktop, fills opposite side) */}
                  <div className="hidden md:block flex-1" />

                  {/* Number circle */}
                  <div className="relative z-10 flex-shrink-0 w-[4.7rem] h-[4.7rem] rounded-full border border-white/20 bg-white/5 flex items-center justify-center">
                    <span className="font-serif text-white/50 text-[1.1rem] font-light">
                      {step.num}
                    </span>
                  </div>

                  {/* Card */}
                  <div
                    className={`flex-1 rounded-[1.4rem] border border-white/10 bg-white/5 p-7 hover:bg-white/[0.08] transition-colors duration-300 ${
                      isRight ? "md:text-right" : ""
                    }`}
                  >
                    <h3 className="font-serif text-white text-[1.25rem] font-light leading-snug mb-3">
                      {step.title}
                    </h3>
                    <p className="text-white/55 font-light leading-[1.85] text-[0.92rem]">
                      {step.body}
                    </p>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      </div>
    </section>
  );
}

